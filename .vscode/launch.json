{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug Web App",
            "type": "go",
            "request": "launch",
            "mode": "auto",
            "program": "${workspaceFolder}/web_stuff",
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Debug Current File",
            "type": "go",
            "request": "launch",
            "mode": "auto",
            "program": "${file}"
        },
        {
            "name": "Debug Current Test",
            "type": "go",
            "request": "launch",
            "mode": "test",
            "program": "${fileDirname}",
            "args": [
                "-run",
                "^${selectedText}$"
            ]
        }
    ]
}
